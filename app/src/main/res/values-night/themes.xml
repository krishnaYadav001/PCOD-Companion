<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PCODCompanion" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
    </style>

    <!-- Must extend Theme.SplashScreen for installSplashScreen() to work -->
    <style name="Theme.PCODCompanion.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_background</item>
        <item name="postSplashScreenTheme">@style/Theme.PCODCompanion</item>
    </style>
</resources>

